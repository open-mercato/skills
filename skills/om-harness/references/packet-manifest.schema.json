{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "title", "objective", "risk", "allowedPaths", "invariants", "acceptanceCriteria"],
  "properties": {
    "version": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"
    },
    "title": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "allowedPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"
      }
    },
    "nonGoals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "referencePatterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "worker": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    }
  }
}
